{
  "name": "github-explorer",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "test:ci": "jest --ci",
    "lint": "expo lint",
    "prebuild": "expo prebuild --clean",
    "clean": "rm -rf node_modules .expo ios android && rm -rf ~/Library/Developer/Xcode/DerivedData/*",
    "clean:ios": "rm -rf ios && rm -rf ~/Library/Developer/Xcode/DerivedData/*",
    "clean:android": "rm -rf android",
    "fresh-install": "npm run clean && npm install",
    "setup:ios": "npm run clean:ios && npm install && npx expo prebuild --clean --platform ios",
    "setup:ios:device": "npm run setup:ios && npx expo run:ios --device",
    "setup:android": "npm run clean:android && npm install && npx expo prebuild --clean --platform android && cd android && ./gradlew clean && cd ..",
    "setup:android:device": "npm run setup:android && npx expo run:android --device"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.4",
    "@reduxjs/toolkit": "^2.11.2",
    "axios": "^1.13.6",
    "expo": "~55.0.5",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.9",
    "react": "19.2.4",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-mmkv": "^4.2.0",
    "react-native-reanimated": "~4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.12.0",
    "react-redux": "^9.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.2.2",
    "babel-plugin-module-resolver": "^5.0.2",
    "typescript": "~5.9.2",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.9",
    "@testing-library/react-native": "^13.3.3",
    "babel-jest": "^29.7.0",
    "react-test-renderer": "19.2.4"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|react-navigation|@react-navigation/.*|react-native-mmkv|react-native-svg|@reduxjs)"
    ]
  }
}
